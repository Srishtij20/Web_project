<% layout("/layouts/boilerplate") %>

<div id="filters" class="d-flex flex-wrap align-items-center gap-1 pt-3 pb-2 border-bottom">
  <% const categories = [
    { slug: "",               icon: "fa-fire",            label: "All" },
    { slug: "trending",       icon: "fa-arrow-trend-up",  label: "Trending" },
    { slug: "rooms",          icon: "fa-bed",             label: "Rooms" },
    { slug: "iconic cities",  icon: "fa-mountain-city",   label: "Iconic Cities" },
    { slug: "mountains",      icon: "fa-mountain",        label: "Mountains" },
    { slug: "castles",        icon: "fa-chess-rook",      label: "Castles" },
    { slug: "amazing pools",  icon: "fa-person-swimming", label: "Amazing Pools" },
    { slug: "camping",        icon: "fa-campground",      label: "Camping" },
    { slug: "farms",          icon: "fa-cow",             label: "Farms" },
    { slug: "arctic",         icon: "fa-snowflake",       label: "Arctic" },
    { slug: "domes",          icon: "fa-igloo",           label: "Domes" },
    { slug: "boats",          icon: "fa-ship",            label: "Boats" },
    { slug: "beach",          icon: "fa-umbrella-beach",  label: "Beach" },
  ]; %>

  <% for (let cat of categories) { %>
    <a href="/listings?category=<%= cat.slug %><%= typeof search !== 'undefined' && search ? '&search=' + search : '' %>"
       class="filter-pill <%= (typeof category !== 'undefined' && category === cat.slug) || (!cat.slug && !category) ? 'active' : '' %>">
      <i class="fa-solid <%= cat.icon %>"></i>
      <span><%= cat.label %></span>
    </a>
  <% } %>

  <div class="ms-auto d-flex align-items-center gap-3 flex-wrap">
    <form method="GET" action="/listings" id="sortForm" class="d-flex align-items-center gap-2">
      <input type="hidden" name="category" value="<%= typeof category !== 'undefined' ? category : '' %>" />
      <input type="hidden" name="search" value="<%= typeof search !== 'undefined' ? search : '' %>" />
      <select name="sort" class="form-select form-select-sm rounded-pill" style="width:auto;" onchange="document.getElementById('sortForm').submit()">
        <option value="" <%= !sort ? 'selected' : '' %>>Sort by</option>
        <option value="price_asc"  <%= sort === 'price_asc'  ? 'selected' : '' %>>Price: Low → High</option>
        <option value="price_desc" <%= sort === 'price_desc' ? 'selected' : '' %>>Price: High → Low</option>
        <option value="newest"     <%= sort === 'newest'     ? 'selected' : '' %>>Newest first</option>
      </select>
    </form>
    <div class="tax-toggle d-flex align-items-center gap-2 border rounded-pill px-3 py-2">
      <div class="form-check form-switch mb-0">
        <input class="form-check-input" type="checkbox" role="switch" id="taxToggle" />
        <label class="form-check-label small" for="taxToggle">Show total with taxes</label>
      </div>
    </div>
  </div>
</div>

<div class="d-flex align-items-center justify-content-between mt-3 mb-1">
  <p class="text-muted small mb-0">
    <% if (search) { %>
      <b><%= allListings.length %></b> result<%= allListings.length !== 1 ? 's' : '' %> for "<b><%= search %></b>"
      <a href="/listings" class="ms-2 text-danger text-decoration-none small">✕ Clear</a>
    <% } else if (category) { %>
      <b><%= allListings.length %></b> listing<%= allListings.length !== 1 ? 's' : '' %> in <b><%= category %></b>
    <% } else { %>
      <b><%= allListings.length %></b> listing<%= allListings.length !== 1 ? 's' : '' %> available
    <% } %>
  </p>
</div>

<% if (allListings.length === 0) { %>
  <div class="empty-state text-center py-5 mt-4">
    <i class="fa-solid fa-magnifying-glass fa-3x text-muted mb-3"></i>
    <h4 class="text-muted">No listings found</h4>
    <p class="text-muted">Try a different search or category</p>
    <a href="/listings" class="btn btn-dark rounded-pill px-4">View all listings</a>
  </div>
<% } %>

<div class="row row-cols-xl-4 row-cols-lg-3 row-cols-md-2 row-cols-sm-1 g-4 mt-1">
  <% for (let listing of allListings) { %>
    <div class="col">
      <a href="/listings/<%= listing._id %>" class="text-decoration-none text-dark listing-link">
        <div class="listing-card">
          <div class="listing-img-wrap">
            <img src="<%= listing.image.url %>" alt="<%= listing.title %>" class="listing-img" loading="lazy" />
            <% if (typeof currUser !== 'undefined' && currUser) { %>
              <form method="POST" action="/listings/<%= listing._id %>/wishlist" class="wishlist-form">
                <button type="submit" class="wishlist-btn" title="Save">
                  <i class="fa-heart <%= typeof currUser !== 'undefined' && currUser && currUser.wishlist && currUser.wishlist.map(String).includes(listing._id.toString()) ? 'fa-solid text-danger' : 'fa-regular' %>"></i>
                </button>
              </form>
            <% } %>
            <% if (listing.category) { %>
              <span class="category-badge"><%= listing.category %></span>
            <% } %>
          </div>
          <div class="listing-body">
            <div class="d-flex justify-content-between align-items-start">
              <h6 class="listing-title mb-1"><%= listing.title %></h6>
            </div>
            <p class="listing-location text-muted small mb-1">
              <i class="fa-solid fa-location-dot me-1"></i><%= listing.location %>, <%= listing.country %>
            </p>
            <p class="listing-price mb-0">
              <b>&#8377;<%= Number(listing.price).toLocaleString("en-IN") %></b>
              <span class="text-muted small"> / night</span>
              <span class="tax-info text-muted small d-none">
                &nbsp;· &#8377;<%= Math.round(listing.price * 1.18).toLocaleString("en-IN") %> total with taxes
              </span>
            </p>
          </div>
        </div>
      </a>
    </div>
  <% } %>
</div>

<script>
  document.getElementById("taxToggle").addEventListener("change", function () {
    document.querySelectorAll(".tax-info").forEach(el => el.classList.toggle("d-none", !this.checked));
  });
  document.querySelectorAll(".wishlist-form").forEach(form => {
    form.addEventListener("click", e => e.stopPropagation());
  });
</script>