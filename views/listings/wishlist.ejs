<% layout("/layouts/boilerplate") %>
<div class="mt-4 mb-5">
  <h3 class="fw-bold mb-1"><i class="fa-solid fa-heart text-danger me-2"></i>My Wishlist</h3>
  <p class="text-muted mb-4">Places you've saved for later</p>
  <% if (wishlist.length === 0) { %>
    <div class="text-center py-5 border rounded-4">
      <i class="fa-regular fa-heart fa-4x text-muted mb-3"></i>
      <h5 class="text-muted">Your wishlist is empty</h5>
      <p class="text-muted small">Click the heart on any listing to save it here</p>
      <a href="/listings" class="btn btn-dark rounded-pill px-4 mt-2">Explore listings</a>
    </div>
  <% } else { %>
    <div class="row row-cols-xl-4 row-cols-lg-3 row-cols-md-2 row-cols-sm-1 g-4">
      <% wishlist.forEach(listing => { %>
        <div class="col">
          <div class="listing-card">
            <div class="listing-img-wrap">
              <img src="<%= listing.image.url %>" alt="<%= listing.title %>" class="listing-img" />
              <form method="POST" action="/listings/<%= listing._id %>/unwishlist" class="wishlist-form">
                <button type="submit" class="wishlist-btn"><i class="fa-solid fa-heart text-danger"></i></button>
              </form>
            </div>
            <div class="listing-body">
              <h6 class="listing-title mb-1"><%= listing.title %></h6>
              <p class="listing-location text-muted small mb-1">
                <i class="fa-solid fa-location-dot me-1"></i><%= listing.location %>, <%= listing.country %>
              </p>
              <p class="listing-price mb-2">
                <b>&#8377;<%= Number(listing.price).toLocaleString("en-IN") %></b>
                <span class="text-muted small"> / night</span>
              </p>
              <a href="/listings/<%= listing._id %>" class="btn btn-dark btn-sm rounded-pill px-3 w-100">View listing</a>
            </div>
          </div>
        </div>
      <% }) %>
    </div>
  <% } %>
</div>