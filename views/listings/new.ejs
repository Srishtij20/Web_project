<% layout("/layouts/boilerplate") %>
<div class="row justify-content-center mt-4 mb-5">
  <div class="col-lg-7 col-md-9">
    <div class="p-4 p-md-5 border rounded-4 shadow-sm">
      <h3 class="fw-bold mb-1">Create a new listing</h3>
      <p class="text-muted mb-4 small">Share your space with travellers around the world</p>
      <form method="POST" action="/listings" novalidate class="needs-validation" enctype="multipart/form-data">
        <div class="mb-3">
          <label class="form-label fw-semibold">Title <span class="text-danger">*</span></label>
          <input name="listing[title]" type="text" class="form-control rounded-3" placeholder="e.g. Cozy beachfront cottage in Goa" required />
          <div class="invalid-feedback">Please enter a title</div>
        </div>
        <div class="mb-3">
          <label class="form-label fw-semibold">Description <span class="text-danger">*</span></label>
          <textarea name="listing[description]" class="form-control rounded-3" rows="4" placeholder="Describe your place..." required></textarea>
          <div class="invalid-feedback">Please enter a description</div>
        </div>
        <div class="mb-3">
          <label class="form-label fw-semibold">Listing image <span class="text-danger">*</span></label>
          <input name="listing[image]" type="file" class="form-control rounded-3" accept="image/*" required id="imageInput" onchange="previewImage(event)" />
          <div class="mt-2" id="imagePreviewWrap" style="display:none;">
            <img id="imagePreview" src="" alt="Preview" class="rounded-3" style="max-height:200px; object-fit:cover; width:100%;" />
          </div>
        </div>
        <div class="mb-3">
          <label class="form-label fw-semibold">Category</label>
          <select name="listing[category]" class="form-select rounded-3">
            <option value="trending">Trending</option>
            <option value="rooms">Rooms</option>
            <option value="iconic cities">Iconic Cities</option>
            <option value="mountains">Mountains</option>
            <option value="castles">Castles</option>
            <option value="amazing pools">Amazing Pools</option>
            <option value="camping">Camping</option>
            <option value="farms">Farms</option>
            <option value="arctic">Arctic</option>
            <option value="domes">Domes</option>
            <option value="boats">Boats</option>
            <option value="beach">Beach</option>
          </select>
        </div>
        <div class="row g-3 mb-3">
          <div class="col-md-4">
            <label class="form-label fw-semibold">Price / night (₹) <span class="text-danger">*</span></label>
            <div class="input-group">
              <span class="input-group-text">₹</span>
              <input name="listing[price]" type="number" class="form-control" placeholder="1200" min="0" required />
            </div>
          </div>
          <div class="col-md-8">
            <label class="form-label fw-semibold">Country <span class="text-danger">*</span></label>
            <input name="listing[country]" type="text" class="form-control rounded-3" placeholder="India" required />
          </div>
        </div>
        <div class="mb-4">
          <label class="form-label fw-semibold">Location <span class="text-danger">*</span></label>
          <input name="listing[location]" type="text" class="form-control rounded-3" placeholder="Jaipur, Rajasthan" required />
        </div>
        <button class="btn btn-dark rounded-pill px-5 py-2 fw-semibold w-100">
          <i class="fa-solid fa-plus me-2"></i>Create listing
        </button>
      </form>
    </div>
  </div>
</div>
<script>
  function previewImage(event) {
    const file = event.target.files[0];
    if (!file) return;
    document.getElementById("imagePreview").src = URL.createObjectURL(file);
    document.getElementById("imagePreviewWrap").style.display = "block";
  }
</script>